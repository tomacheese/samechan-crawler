{
  "name": "samechan-crawler",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "index.js",
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "scripts": {
    "start": "tsx ./src/main.ts",
    "dev": "tsx --watch ./src/main.ts",
    "package": "run-z clean compile packing",
    "packing": "ncc build ./dist/main.js -o output/",
    "compile": "tsc -p .",
    "clean": "rimraf dist output",
    "lint": "run-z lint:prettier,lint:eslint,lint:tsc",
    "lint:prettier": "prettier --check src",
    "lint:eslint": "eslint . -c eslint.config.mjs",
    "lint:tsc": "tsc",
    "fix": "run-z fix:prettier fix:eslint",
    "fix:eslint": "eslint . -c eslint.config.mjs --fix",
    "fix:prettier": "prettier --write src",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@book000/node-utils": "1.24.270",
    "@the-convocation/twitter-scraper": "0.22.3",
    "cycletls": "2.0.5",
    "headers-polyfill": "5.0.1",
    "twitter-openapi-typescript": "0.0.56"
  },
  "devDependencies": {
    "@book000/eslint-config": "1.15.4",
    "@types/node": "24.13.2",
    "@types/tough-cookie": "4.0.5",
    "@vercel/ncc": "0.44.1",
    "eslint": "10.6.0",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.2.1",
    "eslint-plugin-promise": "7.3.0",
    "prettier": "3.9.4",
    "rimraf": "6.1.3",
    "run-z": "2.1.0",
    "tsx": "4.22.5",
    "typescript": "6.0.3"
  }
}
